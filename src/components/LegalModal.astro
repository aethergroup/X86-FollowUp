---
interface Props {
  isOpen: boolean;
  onClose: () => void;
  type: 'privacy' | 'terms' | 'cookies';
}

const { isOpen, onClose, type } = Astro.props;

const getModalContent = (type: string) => {
  switch(type) {
    case 'privacy':
      return {
        title: 'Políticas de Privacidad',
        content: `
          <h2>Política de Privacidad de Follow Up</h2>
          <p><strong>Fecha de entrada en vigor:</strong> 21 de marzo de 2026</p>
          
          <h3>1. Información que recopilamos</h3>
          <p>Recopilamos información personal que nos proporciona voluntariamente al utilizar nuestros servicios, incluyendo:</p>
          <ul>
            <li>Nombre y datos de contacto</li>
            <li>Información de facturación</li>
            <li>Datos de uso del servicio</li>
            <li>Comunicaciones con nuestro equipo de soporte</li>
          </ul>
          
          <h3>2. Uso de la información</h3>
          <p>Utilizamos su información para:</p>
          <ul>
            <li>Prestar y mantener nuestros servicios</li>
            <li>Mejorar y personalizar la experiencia del usuario</li>
            <li>Comunicarnos con usted sobre actualizaciones y soporte</li>
            <li>Cumplir con obligaciones legales</li>
          </ul>
          
          <h3>3. Compartir información</h3>
          <p>No vendemos, alquilamos ni compartimos su información personal con terceros para fines comerciales, excepto cuando:</p>
          <ul>
            <li>Usted nos da su consentimiento explícito</li>
            <li>Es necesario para prestar el servicio</li>
            <li>Lo exige la ley</li>
          </ul>
          
          <h3>4. Seguridad de datos</h3>
          <p>Implementamos medidas de seguridad técnicas y organizativas para proteger su información contra acceso no autorizado, alteración o destrucción.</p>
          
          <h3>5. Sus derechos</h3>
          <p>Usted tiene derecho a:</p>
          <ul>
            <li>Acceder a su información personal</li>
            <li>Corregir información inexacta</li>
            <li>Eliminar su información personal</li>
            <li>Limitar el procesamiento de sus datos</li>
          </ul>
        `
      };
    case 'terms':
      return {
        title: 'Términos y Condiciones',
        content: `
          <h2>Términos y Condiciones de Follow Up</h2>
          <p><strong>Fecha de entrada en vigor:</strong> 21 de marzo de 2026</p>
          
          <h3>1. Aceptación de los términos</h3>
          <p>Al utilizar los servicios de Follow Up, usted acepta estos términos y condiciones. Si no está de acuerdo, no debe utilizar nuestros servicios.</p>
          
          <h3>2. Descripción del servicio</h3>
          <p>Follow Up es una plataforma de seguimiento de clientes y gestión de relaciones comerciales que ayuda a las empresas a mantener contacto con sus clientes y gestionar sus interacciones comerciales.</p>
          
          <h3>3. Responsabilidades del usuario</h3>
          <p>Como usuario, usted se compromete a:</p>
          <ul>
            <li>Proporcionar información veraz y actualizada</li>
            <li>Utilizar el servicio para fines legítimos</li>
            <li>No violar derechos de terceros</li>
            <li>Mantener la confidencialidad de sus credenciales</li>
          </ul>
          
          <h3>4. Pagos y suscripciones</h3>
          <p>Los pagos se procesan a través de plataformas seguras. Las suscripciones se renuevan automáticamente según el plan seleccionado, salvo cancelación previa.</p>
          
          <h3>5. Propiedad intelectual</h3>
          <p>Todo el contenido, software y propiedad intelectual de Follow Up es propiedad exclusiva de la empresa y está protegido por las leyes de propiedad intelectual.</p>
          
          <h3>6. Limitación de responsabilidad</h3>
          <p>Follow Up no será responsable por daños indirectos, incidentales o consecuentes que resulten del uso o la incapacidad de usar nuestros servicios.</p>
          
          <h3>7. Modificaciones del servicio</h3>
          <p>Nos reservamos el derecho de modificar, suspender o discontinuar cualquier parte del servicio en cualquier momento sin previo aviso.</p>
          
          <h3>8. Terminación</h3>
          <p>Podemos terminar su acceso al servicio por violación de estos términos o por cualquier otra razón que consideremos apropiada.</p>
        `
      };
    case 'cookies':
      return {
        title: 'Política de Uso de Cookies',
        content: `
          <h2>Política de Uso de Cookies de Follow Up</h2>
          <p><strong>Fecha de entrada en vigor:</strong> 21 de marzo de 2026</p>
          
          <h3>1. ¿Qué son las cookies?</h3>
          <p>Las cookies son pequeños archivos de texto que se almacenan en su dispositivo cuando visita un sitio web. Nos ayudan a mejorar su experiencia de navegación.</p>
          
          <h3>2. Tipos de cookies que utilizamos</h3>
          
          <h4>Cookies esenciales</h4>
          <p>Son necesarias para el funcionamiento básico del sitio web:</p>
          <ul>
            <li>Mantener la sesión de usuario</li>
            <li>Recordar preferencias básicas</li>
            <li>Gestionar la seguridad del sitio</li>
          </ul>
          
          <h4>Cookies de rendimiento</h4>
          <p>Nos ayudan a entender cómo utiliza nuestro sitio:</p>
          <ul>
            <li>Análisis de tráfico y uso</li>
            <li>Medición de rendimiento</li>
            <li>Identificación de problemas técnicos</li>
          </ul>
          
          <h4>Cookies de funcionalidad</h4>
          <p>Mejoran su experiencia personalizada:</p>
          <ul>
            <li>Recordar sus preferencias</li>
            <li>Personalizar contenido</li>
            <li>Guardar configuraciones de idioma</li>
          </ul>
          
          <h3>3. ¿Cómo gestionar las cookies?</h3>
          <p>Puede controlar las cookies a través de:</p>
          <ul>
            <li>La configuración de su navegador</li>
            <li>Nuestro panel de preferencias de cookies</li>
            <li>La eliminación manual de cookies almacenadas</li>
          </ul>
          
          <h3>4. Cookies de terceros</h3>
          <p>Utilizamos servicios de terceros que pueden instalar sus propias cookies:</p>
          <ul>
            <li>Google Analytics (análisis)</li>
            <li>Proveedores de pago seguro</li>
            <li>Servicios de chat de soporte</li>
          </ul>
          
          <h3>5. Actualizaciones de esta política</h3>
          <p>Podemos actualizar esta política de cookies ocasionalmente. Le recomendamos revisar esta página periódicamente para estar informado sobre cualquier cambio.</p>
        `
      };
    default:
      return { title: '', content: '' };
  }
};

const modalData = getModalContent(type);
---

<div id="legal-modal" class={isOpen ? '' : 'hidden'} class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black bg-opacity-50 backdrop-blur-sm" 
     role="dialog" 
     aria-modal="true" 
     aria-labelledby="modal-title">
  <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="bg-[#102c26] text-white px-6 py-4 flex justify-between items-center">
      <h2 id="modal-title" class="text-xl font-bold text-green-400">{modalData.title}</h2>
      <button 
        onclick={onClose}
        class="text-white hover:text-green-400 transition-colors duration-200 p-1 rounded"
        aria-label="Cerrar modal">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Content -->
    <div class="flex-1 overflow-y-auto p-6 text-gray-800">
      <div set:html={modalData.content} class="legal-content">
      </div>
    </div>
    
    <!-- Footer -->
    <div class="bg-gray-100 px-6 py-4 border-t">
      <button 
        onclick={onClose}
        class="bg-[#102c26] text-white px-6 py-2 rounded hover:bg-green-700 transition-colors duration-200 w-full md:w-auto">
        Cerrar
      </button>
    </div>
  </div>
</div>

<style>
  #legal-modal {
    display: none;
  }
  
  #legal-modal:not([hidden]) {
    display: flex;
  }

  .legal-content h2 {
    font-size: 1.5rem;
    font-weight: bold;
    color: #102c26;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  
  .legal-content h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #102c26;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  
  .legal-content h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #102c26;
    margin-top: 0.75rem;
    margin-bottom: 0.5rem;
  }
  
  .legal-content p {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }
  
  .legal-content ul {
    list-style: disc;
    list-style-position: inside;
    margin-bottom: 0.75rem;
  }
  
  .legal-content li {
    margin-left: 0.5rem;
  }
  
  .legal-content strong {
    font-weight: 600;
    color: #102c26;
  }
  
  /* Mobile-first responsive styles */
  @media (max-width: 767px) {
    #legal-modal {
      padding: 1rem;
    }
    
    #legal-modal .bg-white {
      max-width: 100%;
    }
    
    #legal-modal .max-h-\[90vh\] {
      max-height: 95vh;
    }
    
    #legal-modal .px-6 {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    
    .legal-content h2 {
      font-size: 1.25rem;
    }
    
    .legal-content h3 {
      font-size: 1rem;
    }
  }
  
  /* Smooth transitions */
  #legal-modal {
    animation: fadeIn 0.3s ease-out;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  
  #legal-modal .bg-white {
    animation: slideUp 0.3s ease-out;
  }
  
  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
