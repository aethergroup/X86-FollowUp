---
import "../styles/global.css";
import plansData from "../data/plans.json";
---

<main class="min-h-screen bg-gray-50 py-12 px-4" role="main">
    <div class="container mx-auto">
        <!-- Header Section -->
        <div class="text-center mb-12">
            <h1 class="text-3xl md:text-4xl font-bold font-sans text-[#102c26] mb-4">
                Elige tu plan ideal
            </h1>
            <p class="text-lg font-narrow text-gray-600 max-w-2xl mx-auto">
                Planes diseñados para gimnasios de todos los tamaños. Desde pequeños emprendimientos hasta grandes cadenas.
            </p>
        </div>

        <!-- Pricing Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {plansData.plans.map((plan) => (
                <div class={`relative bg-white rounded-2xl shadow-lg p-8 ${plan.popular ? 'ring-2 ring-green-600 transform scale-105' : ''}`} role="article">
                    {plan.popular && (
                        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                            <span class="bg-green-600 text-white px-4 py-1 rounded-full text-sm font-medium">
                                Más popular
                            </span>
                        </div>
                    )}
                    
                    <div class="text-center mb-8">
                        <h3 class="text-2xl font-bold font-sans text-[#102c26] mb-2">
                            {plan.name}
                        </h3>
                        <div class="mb-4">
                            <span class="text-4xl font-bold text-[#102c26]">{plan.price}</span>
                            <span class="text-gray-600">{plan.period}</span>
                        </div>
                        <p class="text-gray-600 font-narrow">
                            {plan.description}
                        </p>
                    </div>

                    <ul class="space-y-4 mb-8">
                        {plan.features.map((feature) => (
                            <li class="flex items-start">
                                <svg class="w-5 h-5 text-green-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span class="text-gray-700 font-narrow">{feature}</span>
                            </li>
                        ))}
                    </ul>

                    <button class={`w-full py-3 px-6 rounded-lg font-medium transition-colors ${
                        plan.popular 
                            ? 'bg-green-600 hover:bg-green-700 text-white' 
                            : 'border-2 border-[#102c26] text-[#102c26] hover:bg-[#102c26] hover:text-white'
                    }`} aria-label={`${plan.cta} - Plan ${plan.name}`}>
                        {plan.id === 'enterprise' ? (
                            <a href={`https://wa.me/${import.meta.env.PHONE_NUMBER}?text=Hola%2C%20estoy%20interesado%20en%20el%20plan%20Enterprise`} target="_blank">
                                {plan.cta}
                            </a>
                        ) : (
                            <a href={`https://wa.me/${import.meta.env.PHONE_NUMBER}?text=Hola%2C%20quiero%20contratar%20el%20plan%20${plan.name}`} target="_blank">
                                {plan.cta}
                            </a>
                        )}
                    </button>
                </div>
            ))}
        </div>

        <!-- FAQ Section -->
        <div class="mt-20 max-w-4xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold font-sans text-[#102c26] text-center mb-12">
                Preguntas frecuentes
            </h2>
            <div class="space-y-6">
                <div class="bg-white rounded-lg p-6 shadow-sm">
                    <h3 class="text-lg font-semibold font-sans text-[#102c26] mb-3">
                        ¿Puedo cambiar de plan en cualquier momento?
                    </h3>
                    <p class="text-gray-600 font-narrow">
                        Sí, puedes actualizar o downgrade tu plan en cualquier momento. Los cambios se reflejarán en tu siguiente facturación.
                    </p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-sm">
                    <h3 class="text-lg font-semibold font-sans text-[#102c26] mb-3">
                        ¿Qué métodos de pago aceptan?
                    </h3>
                    <p class="text-gray-600 font-narrow">
                        Aceptamos tarjetas de crédito/débito, transferencias bancarias y billeteras digitales. Todo 100% digital.
                    </p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-sm">
                    <h3 class="text-lg font-semibold font-sans text-[#102c26] mb-3">
                        ¿Hay un período de prueba?
                    </h3>
                    <p class="text-gray-600 font-narrow">
                        Sí, ofrecemos 14 días de prueba gratuita en todos los planes. Sin compromiso, puedes cancelar cuando quieras.
                    </p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-sm">
                    <h3 class="text-lg font-semibold font-sans text-[#102c26] mb-3">
                        ¿Mis datos están seguros?
                    </h3>
                    <p class="text-gray-600 font-narrow">
                        Por supuesto. Utilizamos encriptación de nivel bancario y cumplimos con todas las normativas de protección de datos.
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <div class="mt-20 text-center bg-[#102c26] rounded-2xl p-12 text-white">
            <h2 class="text-2xl md:text-3xl font-bold font-sans mb-4">
                ¿Necesitas ayuda para elegir?
            </h2>
            <p class="text-lg font-narrow mb-8 max-w-2xl mx-auto opacity-90">
                Nuestro equipo de expertos está listo para ayudarte a encontrar el plan perfecto para tu gimnasio.
            </p>
            <button class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg font-medium transition-colors">
                <a href={`https://wa.me/${import.meta.env.PHONE_NUMBER}?text=Hola%2C%20necesito%20ayuda%20para%20elegir%20un%20plan`} target="_blank">
                    Hablar con un experto
                </a>
            </button>
        </div>
    </div>
</main>